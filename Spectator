local DI = DrawingImmediate

local function fR(x,y,w,h,c,op)
    DI.FilledRectangle(Vector2.new(x,y), Vector2.new(w,h), c, op or 1)
end
local function sR(x,y,w,h,c,op,t)
    DI.Rectangle(Vector2.new(x,y), Vector2.new(w,h), c, op or 1, t or 1)
end
local function tx(x,y,sz,c,s,cen)
    DI.OutlinedText(Vector2.new(x,y), sz, c, 1, s, cen or false, "Tamzen")
end

local function mkSq(els,x,y,w,h,col,filled,rnd,op,thick)
    local s = Drawing.new("Square")
    s.Visible=true; s.Position=Vector2.new(x,y); s.Size=Vector2.new(w,h)
    s.Color=col; s.Filled=filled; s.Rounding=rnd or 0; s.Opacity=op or 1
    if not filled then s.Thickness = thick or 1 end
    table.insert(els, s); return s
end
local function mkTx(els,x,y,sz,col,str,center)
    local t = Drawing.new("Text")
    t.Visible=true; t.Position=Vector2.new(x,y); t.Size=sz
    t.Color=col; t.Text=str; t.Outline=true; t.Center=center or false
    table.insert(els, t); return t
end
local function mkCi(els,x,y,r,col,filled,sides,thick)
    local c = Drawing.new("Circle")
    c.Visible=true; c.Position=Vector2.new(x,y); c.Radius=r
    c.Color=col; c.Filled=filled; c.NumSides=sides or 24
    if not filled then c.Thickness = thick or 2 end
    table.insert(els, c); return c
end
local function clearEls(t)
    for _,e in ipairs(t) do pcall(function() e:Remove() end) end
    for k in pairs(t) do t[k]=nil end
end

