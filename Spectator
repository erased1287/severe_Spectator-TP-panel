local function clearThm() clearEls(thmEls); thmAcc={}; thmBg={}; thmClose=nil end

local function drawThm()
    clearThm()
    local vpx,vpy = getVP()
    local COLS = 5; local swH,swG = 52,6; local W = 430
    local ra = math.ceil(#AccPre/COLS); local rb = math.ceil(#BgPre/3)
    local H = O_HDR + (O_SEC+14) + ra*(swH+swG) + 10 + (O_SEC+14) + rb*(swH+swG) + 20
    local x = math.floor(vpx/2-W/2); local y = math.floor(vpy/2-H/2)
    mkSq(thmEls,x-6,y-6,W+12,H+12,T.blk,true,18,0.55)
    mkSq(thmEls,x,y,W,H,T.bg1,true,10)
    mkSq(thmEls,x,y,W,H,T.brdr,false,10,1,1)
    mkSq(thmEls,x,y,IR,H,T.acc,true,2)
    mkSq(thmEls,x,y,W,O_HDR,T.bg2,true,10)
    mkSq(thmEls,x,y+O_HDR-1,W,1,T.line,true)
    mkSq(thmEls,x,y,IR,O_HDR,T.acc,true,2)
    mkCi(thmEls,x+26,y+O_HDR/2,12,T.acc,false,24,2)
    mkTx(thmEls,x+26,y+O_HDR/2-7,12,T.acc,"S",true)
    mkTx(thmEls,x+46,y+14,13,T.t0,"Customize Theme",false)
    mkTx(thmEls,x+46,y+30,9,T.t2,"Accent | Background",false)
    local cx,cy = x+W-34, y+13
    mkSq(thmEls,cx,cy,22,22,T.bg4,true,5)
    mkTx(thmEls,cx+11,cy+3,16,T.t1,"x",true)
    thmClose={x=cx,y=cy,w=22,h=22}
    local sw = math.floor((W-PAD*2-swG*(COLS-1))/COLS)
    local iy = y+O_HDR+8
    -- accent label
    mkSq(thmEls,x+PAD,iy,W-PAD*2,O_SEC,T.bg2,true,4)
    mkSq(thmEls,x+PAD,iy,2,O_SEC,T.acc,true)
    mkTx(thmEls,x+PAD+10,iy+(O_SEC-9)/2,9,T.t2,"ACCENT COLOUR",false)
    iy += O_SEC+8
    local sx = x+PAD
    for i,p in ipairs(AccPre) do
        local sel = (math.abs(T.acc.R-p.a.R)<0.01 and math.abs(T.acc.G-p.a.G)<0.01)
        mkSq(thmEls,sx,iy,sw,swH,sel and T.bg4 or T.bg3,true,5)
        if sel then mkSq(thmEls,sx,iy,sw,swH,T.acc,false,5,1,2); mkSq(thmEls,sx,iy,2,swH,T.acc,true,2) end
        local hw = math.floor((sw-8)/2)
        mkSq(thmEls,sx+4,iy+6,hw,swH-20,p.a,true,3)
        mkSq(thmEls,sx+4+hw+2,iy+6,hw,swH-20,p.s,true,3)
        mkTx(thmEls,sx+sw/2,iy+swH-13,8,T.t1,p.n,true)
        table.insert(thmAcc,{x=sx,y=iy,w=sw,h=swH}); sx+=sw+swG
        if i%COLS==0 then sx=x+PAD; iy+=swH+swG end
    end
    if #AccPre%COLS~=0 then iy+=swH+swG end; iy+=8
    -- bg label
    mkSq(thmEls,x+PAD,iy,W-PAD*2,O_SEC,T.bg2,true,4)
    mkSq(thmEls,x+PAD,iy,2,O_SEC,T.acc,true)
    mkTx(thmEls,x+PAD+10,iy+(O_SEC-9)/2,9,T.t2,"BACKGROUND",false)
    iy+=O_SEC+8
    local BC=3; local sw2=math.floor((W-PAD*2-swG*(BC-1))/BC); sx=x+PAD
    for i,p in ipairs(BgPre) do
        local sel=(math.abs(T.bg1.R-p.b1.R)<0.01 and math.abs(T.bg1.G-p.b1.G)<0.01)
        mkSq(thmEls,sx,iy,sw2,swH,sel and T.bg4 or T.bg3,true,5)
        if sel then mkSq(thmEls,sx,iy,sw2,swH,T.acc,false,5,1,2); mkSq(thmEls,sx,iy,2,swH,T.acc,true,2) end
        local tw=math.floor((sw2-10)/3)
        mkSq(thmEls,sx+4,      iy+6,tw,swH-20,p.b1,true,3)
        mkSq(thmEls,sx+4+tw+2, iy+6,tw,swH-20,p.b2,true,3)
        mkSq(thmEls,sx+4+tw*2+4,iy+6,tw,swH-20,p.b3,true,3)
        mkTx(thmEls,sx+sw2/2,iy+swH-13,8,T.t1,p.n,true)
        table.insert(thmBg,{x=sx,y=iy,w=sw2,h=swH}); sx+=sw2+swG
        if i%BC==0 then sx=x+PAD; iy+=swH+swG end
    end
end

