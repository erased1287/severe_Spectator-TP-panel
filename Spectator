local function loadAll()
    pcall(function()
        local raw = readfile(SAVE_FILE)
        if not raw then return end
        local d = crypt.json.decode(raw)
        if not d then return end
        local function c(t) return t and Color3.new(t[1],t[2],t[3]) end
        if d.a  then T.acc =c(d.a)  end
        if d.aS then T.accS=c(d.aS) end
        if d.aD then T.accD=c(d.aD) end
        if d.b0 then T.bg0 =c(d.b0) end
        if d.b1 then T.bg1 =c(d.b1) end
        if d.b2 then T.bg2 =c(d.b2) end
        if d.b3 then T.bg3 =c(d.b3) end
        if d.b4 then T.bg4 =c(d.b4) end
        if d.li then T.line=c(d.li)  end
        if d.br then T.brdr=c(d.br)  end
        if d.diedTp     ~= nil then Settings.diedTp     = d.diedTp     end
        if d.thirdP     ~= nil then Settings.thirdP     = d.thirdP     end
        if d.antiVoid   ~= nil then Settings.antiVoid   = d.antiVoid   end
        if d.antiAFK    ~= nil then Settings.antiAFK    = d.antiAFK    end
        if d.instantInt ~= nil then Settings.instantInt = d.instantInt end
        if d.spamFling  ~= nil then Settings.spamFling  = d.spamFling  end
        if d.sustained  ~= nil then Settings.sustained  = d.sustained  end
        if d.spamDelay  ~= nil then Settings.spamDelay  = d.spamDelay  end
        if d.sortMode   ~= nil then Settings.sortMode   = d.sortMode   end
        if d.pX ~= nil then Settings.pX = d.pX end
        if d.pY ~= nil then Settings.pY = d.pY end
