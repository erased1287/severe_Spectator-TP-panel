local function clearSI() clearEls(siEls); siClose=nil; siMain=nil; siCopyBtns={} end

local function drawSI()
    clearSI()
    local vpx,vpy=getVP()
    local W=360; local ROWA=32; local HDW=48
    local rows={
        {lbl="Place ID",  val=tostring(game.PlaceId  or 0)},
        {lbl="Game ID",   val=tostring(game.GameId   or 0)},
        {lbl="Players",   val=tostring(#Players:GetChildren())},
        {lbl="Username",  val=LocalPlayer.Name},
        {lbl="User ID",   val=tostring(LocalPlayer.UserId)},
        {lbl="Job ID",    val=game.JobId and game.JobId:sub(1,20).."..." or "N/A"},
    }
    local H=HDW+(#rows)*(ROWA+4)+16
    local x=math.floor(vpx/2-W/2); local y=math.floor(vpy/2-H/2)

    mkSq(siEls,x-5,y-5,W+10,H+10,T.blk,true,14,0.5)
    mkSq(siEls,x,y,W,H,T.bg1,true,8)
    mkSq(siEls,x,y,W,H,T.brdr,false,8,1,1)
    mkSq(siEls,x,y,IR,H,T.acc,true,2)
    mkSq(siEls,x,y,W,HDW,T.bg2,true,8)
    mkSq(siEls,x,y+HDW-1,W,1,T.line,true)
    mkSq(siEls,x,y,IR,HDW,T.acc,true,2)
    mkCi(siEls,x+24,y+HDW/2,11,T.acc,false,24,2)
    mkTx(siEls,x+24,y+HDW/2-6,11,T.acc,"S",true)
    mkTx(siEls,x+42,y+14,13,T.t0,"Server Info",false)
    mkTx(siEls,x+42,y+29,9,T.t2,"Click any row to copy",false)
    -- close
    local cx,cy=x+W-30,y+12
    mkSq(siEls,cx,cy,20,20,T.bg4,true,4)
    mkTx(siEls,cx+10,cy+3,13,T.t1,"x",true)
    siClose={x=cx,y=cy,w=20,h=20}; siMain={x=x,y=y,w=W,h=H}

    local ry=y+HDW+8
    for _,row in ipairs(rows) do
        -- row bg
        mkSq(siEls,x+PAD,ry,W-PAD*2,ROWA,T.bg3,true,4)
        mkSq(siEls,x+PAD,ry,IR,ROWA,T.util,true,2)
        mkTx(siEls,x+PAD+9, ry+10,9, T.t2,row.lbl,false)
        mkTx(siEls,x+PAD+96,ry+10,9, T.t0,row.val,false)
        -- copy button on right
        local bx=x+W-PAD-36; local bby=ry+(ROWA-16)/2
        mkSq(siEls,bx,bby,36,16,T.bg4,true,3)
        mkSq(siEls,bx,bby,36,16,T.util,false,3,0.4,1)
        mkTx(siEls,bx+18,bby+3,8,T.util,"COPY",true)
        table.insert(siCopyBtns,{x=bx,y=bby,w=36,h=16,val=row.val,lbl=row.lbl})
        ry+=ROWA+4
    end
end

