local function calcOH()
    -- TOGGLES: 7 rows (DiedTP, ThirdP, SpamFling, Sustained, AntiVoid, AntiAFK, InstantInteract)
    -- + 1 interval row
    -- ACTIONS: 4 rows
    -- 3 section bars + header + padding
    return O_HDR + (O_SEC+6)*3 + 8*(O_ROW+O_GAP) + 4*(O_ROW+O_GAP) + 20
end

