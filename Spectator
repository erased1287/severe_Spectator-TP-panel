-- SPECTATE
-- ============================================================
local function stopSpec()
    local prev=specP; specP=nil
    local cam=workspace.CurrentCamera; local mc=LocalPlayer.Character
    if cam and mc then local h=mc:FindFirstChildOfClass("Humanoid"); if h then cam.CameraSubject=h end end
    if prev then notify("Stopped spectating "..prev.Name) end
end
local function startSpec(p)
    if specP then stopSpec() end
    local c=p.Character; if not c then notify("No character: "..p.Name) return end
    local h=c:FindFirstChildOfClass("Humanoid"); if not h then notify("No humanoid: "..p.Name) return end
    specP=p; local cam=workspace.CurrentCamera; if cam then cam.CameraSubject=h end
    notify("Spectating "..p.Name)
end
local function checkSpec()
    if not specP then return end
    local c=specP.Character
    if not c or not c:FindFirstChildOfClass("Humanoid") then stopSpec() end
end

