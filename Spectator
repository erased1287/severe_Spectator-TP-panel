-- ============================================================
local function teleportTo(p)
    local tc=p.Character; local mc=LocalPlayer.Character
    if not tc or not mc then notify("TP failed: no character") return end
    local tr=tc:FindFirstChild("HumanoidRootPart"); local mr=mc:FindFirstChild("HumanoidRootPart")
    if not tr or not mr then notify("TP failed: no RootPart") return end
    tpTgt={x=tr.Position.X,y=tr.Position.Y+2,z=tr.Position.Z}; tpRoot=mr; tpFr=10
    notify("Teleporting to "..p.Name)
end
local function tickTP()
    if tpFr<=0 or not tpRoot or not tpTgt then return end
    pcall(function() tpRoot.CFrame=CFrame.new(tpTgt.x,tpTgt.y,tpTgt.z); tpRoot.Velocity=Vector3.new(0,0,0) end)
    tpFr-=1; if tpFr<=0 then tpTgt=nil; tpRoot=nil end
end

-- ============================================================
-- FLING
-- ============================================================
local function startFling(name)
    if fPhase~="idle" then return end
    if not name or name=="" then notify("No target") return end
    local target=findP(name)
    if not target then notify("Not found: "..tostring(name)) return end
    local thrp=target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not thrp then notify(target.Name.." has no character") return end
    local myHRP=getHRP(); if not myHRP then notify("You have no character") return end
    local pos=myHRP.Position; fSaved={x=pos.X,y=pos.Y,z=pos.Z}
    fTarget=target.Name; fFrames=F.sustained and F_SF or F_QF; fPhase="fling"
    if F.sustained then notify("Sustained fling on "..target.Name)
    else notify("Quick fling on "..target.Name) end
end

