-- ============================================================
local function clearThm() clearEls(thmEls); thmAcc={}; thmBg={}; thmClose=nil; thmHdr=nil end

local function drawThm()
    clearThm()
    local vpx,vpy=getVP()
    local COLS=5; local swH,swG=50,5; local W=420
    local ra=math.ceil(#AccPre/COLS); local rb=math.ceil(#BgPre/3)
    local H=O_HDR+(O_SEC+12)+ra*(swH+swG)+10+(O_SEC+12)+rb*(swH+swG)+18
    -- position: use saved if set, else centre
    if thmX==0 and thmY==0 then
        thmX=math.floor(vpx/2-W/2); thmY=math.floor(vpy/2-H/2)
    end
    thmX=clamp(thmX,0,vpx-W); thmY=clamp(thmY,0,vpy-H)
    local x,y=thmX,thmY

    mkSq(thmEls,x-5,y-5,W+10,H+10,T.blk,true,16,0.5)
    mkSq(thmEls,x,y,W,H,T.bg1,true,8)
    mkSq(thmEls,x,y,W,H,T.brdr,false,8,1,1)
    mkSq(thmEls,x,y,IR,H,T.acc,true,2)
    mkSq(thmEls,x,y,W,O_HDR,T.bg2,true,8)
    mkSq(thmEls,x,y+O_HDR-1,W,1,T.line,true)
    mkSq(thmEls,x,y,IR,O_HDR,T.acc,true,2)
    mkCi(thmEls,x+24,y+O_HDR/2,11,T.acc,false,24,2)
    mkTx(thmEls,x+24,y+O_HDR/2-6,11,T.acc,"S",true)
    mkTx(thmEls,x+42,y+14,13,T.t0,"Customize Theme",false)
    mkTx(thmEls,x+42,y+28,9,T.t2,"Drag header to move",false)
    -- close
    local cx,cy=x+W-30,y+13
    mkSq(thmEls,cx,cy,20,20,T.bg4,true,4)
    mkTx(thmEls,cx+10,cy+3,13,T.t1,"x",true)
    thmClose={x=cx,y=cy,w=20,h=20}
    thmHdr={x=x,y=y,w=W-36,h=O_HDR}

    local sw=math.floor((W-PAD*2-swG*(COLS-1))/COLS)
    local iy=y+O_HDR+8

    -- accent section
    mkSq(thmEls,x+PAD,iy,W-PAD*2,O_SEC,T.bg2,true,3)
    mkSq(thmEls,x+PAD,iy,2,O_SEC,T.acc,true)
    mkTx(thmEls,x+PAD+8,iy+(O_SEC-9)/2,9,T.t2,"ACCENT",false)
    iy+=O_SEC+8

    local sx=x+PAD
    for i,p in ipairs(AccPre) do
        local sel=(math.abs(T.acc.R-p.a.R)<0.01 and math.abs(T.acc.G-p.a.G)<0.01)
        mkSq(thmEls,sx,iy,sw,swH,sel and T.bg4 or T.bg3,true,4)
        if sel then mkSq(thmEls,sx,iy,sw,swH,T.acc,false,4,1,2); mkSq(thmEls,sx,iy,2,swH,T.acc,true,2) end
        local hw=math.floor((sw-8)/2)
        mkSq(thmEls,sx+4,iy+5,hw,swH-18,p.a,true,3)
        mkSq(thmEls,sx+4+hw+2,iy+5,hw,swH-18,p.s,true,3)
        mkTx(thmEls,sx+sw/2,iy+swH-12,8,sel and T.t0 or T.t1,p.n,true)
        table.insert(thmAcc,{x=sx,y=iy,w=sw,h=swH}); sx+=sw+swG
        if i%COLS==0 then sx=x+PAD; iy+=swH+swG end
    end
    if #AccPre%COLS~=0 then iy+=swH+swG end; iy+=8

    -- bg section
    mkSq(thmEls,x+PAD,iy,W-PAD*2,O_SEC,T.bg2,true,3)
    mkSq(thmEls,x+PAD,iy,2,O_SEC,T.acc,true)
    mkTx(thmEls,x+PAD+8,iy+(O_SEC-9)/2,9,T.t2,"BACKGROUND",false)
    iy+=O_SEC+8

    local BC=3; local sw2=math.floor((W-PAD*2-swG*(BC-1))/BC); sx=x+PAD
    for i,p in ipairs(BgPre) do
        local sel=(math.abs(T.bg1.R-p.b1.R)<0.01 and math.abs(T.bg1.G-p.b1.G)<0.01)
        mkSq(thmEls,sx,iy,sw2,swH,sel and T.bg4 or T.bg3,true,4)
        if sel then mkSq(thmEls,sx,iy,sw2,swH,T.acc,false,4,1,2); mkSq(thmEls,sx,iy,2,swH,T.acc,true,2) end
        local tw=math.floor((sw2-10)/3)
        mkSq(thmEls,sx+4,iy+5,tw,swH-18,p.b1,true,3)
        mkSq(thmEls,sx+4+tw+2,iy+5,tw,swH-18,p.b2,true,3)
        mkSq(thmEls,sx+4+tw*2+4,iy+5,tw,swH-18,p.b3,true,3)
        mkTx(thmEls,sx+sw2/2,iy+swH-12,8,sel and T.t0 or T.t1,p.n,true)
        table.insert(thmBg,{x=sx,y=iy,w=sw2,h=swH}); sx+=sw2+swG
        if i%BC==0 then sx=x+PAD; iy+=swH+swG end
    end
end

