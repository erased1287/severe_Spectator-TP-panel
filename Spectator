local function tickDiedTP(dt)
    if not F.diedTp then return end
    if F.dCooldown>0 then F.dCooldown-=dt return end
    pcall(function()
        local c=LocalPlayer.Character; if not c then F.dWasAlive=false return end
        local r=c:FindFirstChild("HumanoidRootPart"); local h=c:FindFirstChildOfClass("Humanoid")
        if not r or not h then F.dWasAlive=false return end
        local alive=h.Health>0
        if alive then F.dLastPos=r.Position end
        if F.dWasAlive and not alive then F.dDeathPos=F.dLastPos; F.dWasDead=true end
        if F.dWasDead and alive and F.dDeathPos then
            local saved=F.dDeathPos
            task.spawn(function()
                task.wait(0.18)
                local nr=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if nr then nr.CFrame=CFrame.new(saved+Vector3.new(0,3,0)); nr.Velocity=Vector3.new(0,0,0); notify("DiedTP: returned") end
            end)
            F.dWasDead=false; F.dDeathPos=nil; F.dCooldown=2
        end
        F.dWasAlive=alive
    end)
end
local function tickThirdP()
    if not F.thirdP then return end
    pcall(function()
        local c=LocalPlayer.Character; local cam=workspace.CurrentCamera
        if not c or not cam then return end
        local head=c:FindFirstChild("Head") or c.PrimaryPart; if not head then return end
        local look=cam.CFrame.LookVector
        cam.CFrame=CFrame.new(head.Position-look*F.tDist+Vector3.new(0,F.tHeight,0),head.Position)
    end)
end
local function tickSpam()
    if not F.spamFling then return end
    if fPhase~="idle" then return end
    if F.spamTarget=="" then return end
    local now=os.clock(); if now-F.spamLast<F.spamDelay then return end
    F.spamLast=now; startFling(F.spamTarget)
end
local function tickAntiVoid(dt)
    if not F.antiVoid then return end
    if F.avCooldown>0 then F.avCooldown-=dt return end
    pcall(function()
        local c=LocalPlayer.Character; if not c then return end
        local r=c:FindFirstChild("HumanoidRootPart"); if not r then return end
        if r.Position.Y<F.avThresh then
            local sp=getSpawn(); r.CFrame=CFrame.new(sp); r.Velocity=Vector3.new(0,0,0)
            F.avCooldown=2; notify("Anti-Void: teleported to spawn")
        end
    end)
end
local function enableAntiAFK()
    if F.afkConn then return end
    F.afkConn=task.spawn(function()
        while F.antiAFK do
            pcall(function()
                local vp=workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize
                if vp then mousemoveabs((vp.X or 960)/2+math.random(-1,1),(vp.Y or 540)/2+math.random(-1,1)) end
            end)
            task.wait(60)
        end
        F.afkConn=nil
    end)
end
-- Instant Interact: zero hold duration on all ProximityPrompts
-- Uses a cached set + DescendantAdded connection to avoid scanning every frame
local iiConn = nil   -- DescendantAdded connection

local function applyII(obj)
    if obj.ClassName ~= "ProximityPrompt" then return end
    pcall(function()
        if F.iiOffset then memory.writef32(obj, F.iiOffset, 0)
        else obj.HoldDuration = 0 end
    end)
end

local function enableInstantInteract()
    if F.iiLoop then return end
    task.spawn(function()
        -- fetch offset once
        local offset = nil
        pcall(function()
            local ok,res = pcall(function()
                return game:HttpGet("https://offsets.ntgetwritewatch.workers.dev/offsets.json")
            end)
            if ok and res then
                local data = crypt.json.decode(res)
                if data and data.ProximityPromptHoldDuraction then
                    offset = tonumber(data.ProximityPromptHoldDuraction, 16)
                end
            end
        end)
        F.iiOffset = offset
        if offset then notify("Instant Interact ON") else notify("Instant Interact ON") end

        -- apply once to all existing prompts
        pcall(function()
            for _,obj in ipairs(game:GetDescendants()) do
                applyII(obj)
            end
        end)

        -- watch for new prompts appearing (no polling loop needed)
        if iiConn then pcall(function() iiConn:Disconnect() end) end
        iiConn = game.DescendantAdded:Connect(function(obj)
            if not F.iiLoop then return end
            task.defer(function() applyII(obj) end)
        end)

        -- light maintenance loop: re-apply every 5s in case game resets values
        F.iiLoop = true
        while F.iiLoop do
            task.wait(5)
            if not F.iiLoop then break end
            pcall(function()
                for _,obj in ipairs(game:GetDescendants()) do
                    applyII(obj)
                end
            end)
        end
    end)
end

local function disableInstantInteract()
    F.iiLoop = false
    F.iiOffset = nil
    if iiConn then pcall(function() iiConn:Disconnect() end); iiConn = nil end
    notify("Instant Interact OFF")
end
local function doForceReset()
    local c=LocalPlayer.Character; if not c then notify("No character") return end
    local done=false
    pcall(function() local h=c:FindFirstChildOfClass("Humanoid"); if h then memory.writef32(h,0x194,0); done=true end end)
    if not done then pcall(function() local h=c:FindFirstChildOfClass("Humanoid"); if h then h.Health=0; done=true end end) end
    if done then notify("Force Reset done") else notify("Force Reset failed") end
end

