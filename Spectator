local function calcOH()
    -- 5 feature toggles + 2 fling toggles + 1 interval = 8 rows + 3 section bars
    return O_HDR+(O_SEC+5)*3+8*(O_ROW+O_GAP)+4*(O_ROW+O_GAP)+18
end

local function clearOpt() clearEls(optEls); optClose=nil; optHdr=nil; optTog={}; optBtn={} end

local function drawOpt()
    clearOpt(); OH=calcOH()
    local vpx,vpy=getVP()
    if optX==0 then optX=pX+PW+10; optY=pY; if optX+OW>vpx then optX=pX-OW-10 end end
    optX=clamp(optX,0,vpx-OW); optY=clamp(optY,0,vpy-OH)
    local x,y=optX,optY

    mkSq(optEls,x-5,y-5,OW+10,OH+10,T.blk,true,14,0.5)
    mkSq(optEls,x,y,OW,OH,T.bg1,true,8)
    mkSq(optEls,x,y,OW,OH,T.brdr,false,8,1,1)
    mkSq(optEls,x,y,IR,OH,T.acc,true,2)
    mkSq(optEls,x,y,OW,O_HDR,T.bg2,true,8)
    mkSq(optEls,x,y+O_HDR-1,OW,1,T.line,true)
    mkSq(optEls,x,y,IR,O_HDR,T.acc,true,2)
    mkCi(optEls,x+24,y+O_HDR/2,11,T.acc,false,24,2)
    mkTx(optEls,x+24,y+O_HDR/2-6,11,T.acc,"S",true)
    mkTx(optEls,x+42,y+13,13,T.t0,"OPTIONS",false)
    mkTx(optEls,x+42,y+28,9,T.t2,"Features | Utilities",false)
    local cx,cy=x+OW-30,y+13
    mkSq(optEls,cx,cy,20,20,T.bg4,true,4)
    mkTx(optEls,cx+10,cy+3,13,T.t1,"x",true)
    optClose={x=cx,y=cy,w=20,h=20}; optHdr={x=x,y=y,w=OW-36,h=O_HDR}

    local W=OW-PAD*2; local iy=y+O_HDR+8

    local function secBar(label)
        mkSq(optEls,x+PAD,iy,W,O_SEC,T.bg2,true,3)
        mkSq(optEls,x+PAD,iy,2,O_SEC,T.acc,true)
        mkTx(optEls,x+PAD+8,iy+(O_SEC-9)/2,9,T.t2,label,false)
        iy+=O_SEC+5
    end

    local function togRow(col,label,desc,isOn)
        mkSq(optEls,x+PAD,iy,W,O_ROW,T.bg3,true,5)
        mkSq(optEls,x+PAD,iy,IR,O_ROW,col,true,2)
        -- status dot
        mkCi(optEls,x+PAD+16,iy+O_ROW/2,4,isOn and col or T.t2,true,12)
        mkTx(optEls,x+PAD+28,iy+9,11,T.t0,label,false)
        mkTx(optEls,x+PAD+28,iy+24,8,T.t1,desc,false)
        -- pill toggle
        local TW,TH=38,18; local tx2=x+PAD+W-TW-8; local ty2=iy+(O_ROW-TH)/2
        mkSq(optEls,tx2,ty2,TW,TH,isOn and T.acc or T.bg4,true,9)
        local kx=isOn and (tx2+TW-15) or (tx2+3)
        mkCi(optEls,kx+6,ty2+TH/2,6,T.wht,true,16)
        table.insert(optTog,{x=tx2,y=ty2,w=TW,h=TH}); iy+=O_ROW+O_GAP
    end

    local function btnRow(col,label,desc,bl)
        mkSq(optEls,x+PAD,iy,W,O_ROW,T.bg3,true,5)
        mkSq(optEls,x+PAD,iy,IR,O_ROW,col,true,2)
        mkCi(optEls,x+PAD+16,iy+O_ROW/2,4,col,true,12)
        mkTx(optEls,x+PAD+28,iy+9,11,T.t0,label,false)
        mkTx(optEls,x+PAD+28,iy+24,8,T.t1,desc,false)
        local BW=56; local bx=x+PAD+W-BW-8; local by=iy+(O_ROW-18)/2
        mkSq(optEls,bx,by,BW,18,col,true,3)
        mkTx(optEls,bx+BW/2,by+4,8,T.wht,bl or "RUN",true)
        table.insert(optBtn,{x=bx,y=by,w=BW,h=18}); iy+=O_ROW+O_GAP
    end

    -- TOGGLES
    secBar("TOGGLES")

    togRow(T.tele,"DiedTP","Auto-return to death location on respawn",F.diedTp)
    optTog[#optTog].fn=function()
        F.diedTp=not F.diedTp
        if F.diedTp then F.dLastPos=nil;F.dDeathPos=nil;F.dWasDead=false;F.dWasAlive=true;F.dCooldown=0 end
        Settings.diedTp=F.diedTp; saveAll()
        if F.diedTp then notify("DiedTP ON") else notify("DiedTP OFF") end
    end

    togRow(T.vis,"Third Person","Force 3rd-person (bypasses FP locks)",F.thirdP)
    optTog[#optTog].fn=function()
        F.thirdP=not F.thirdP
        if not F.thirdP then pcall(function()
            local cam=workspace.CurrentCamera; local mc=LocalPlayer.Character
            if cam and mc then local h=mc:FindFirstChildOfClass("Humanoid"); if h then cam.CameraSubject=h end end
        end) end
        Settings.thirdP=F.thirdP; saveAll()
        if F.thirdP then notify("Third Person ON") else notify("Third Person OFF") end
    end

    togRow(T.move,"Anti-Void","Teleport to spawn when falling below world",F.antiVoid)
    optTog[#optTog].fn=function()
        F.antiVoid=not F.antiVoid; F.avCooldown=0
        if F.antiVoid then F.avSpawn=nil; getSpawn() end
        Settings.antiVoid=F.antiVoid; saveAll()
        if F.antiVoid then notify("Anti-Void ON") else notify("Anti-Void OFF") end
    end

    togRow(T.util,"Anti-AFK","Prevent AFK kick by simulating activity",F.antiAFK)
    optTog[#optTog].fn=function()
        F.antiAFK=not F.antiAFK
        if F.antiAFK then enableAntiAFK() else F.antiAFK=false end
        Settings.antiAFK=F.antiAFK; saveAll()
        if F.antiAFK then notify("Anti-AFK ON") else notify("Anti-AFK OFF") end
    end

    togRow(T.ok,"Instant Interact","Set ProximityPrompt hold duration to 0",F.instantInt)
    optTog[#optTog].fn=function()
        F.instantInt=not F.instantInt
        if F.instantInt then enableInstantInteract() else disableInstantInteract() end
        Settings.instantInt=F.instantInt; saveAll()
    end

    -- FLING CONFIG
    secBar("FLING CONFIG")

    togRow(T.err,"Spam Fling","Auto-fling last FLING target repeatedly",F.spamFling)
    optTog[#optTog].fn=function()
        F.spamFling=not F.spamFling; F.spamLast=os.clock()
        Settings.spamFling=F.spamFling; saveAll()
        if F.spamFling then notify("Spam fling ON") else notify("Spam fling OFF") end
    end

    togRow(T.warn,"Sustained","Longer fling for fall-damage maps",F.sustained)
    optTog[#optTog].fn=function()
        F.sustained=not F.sustained
        Settings.sustained=F.sustained; saveAll()
        if F.sustained then notify("Sustained ON") else notify("Sustained OFF") end
    end

    -- interval row
    do
        mkSq(optEls,x+PAD,iy,W,O_ROW,T.bg3,true,5)
        mkSq(optEls,x+PAD,iy,IR,O_ROW,T.warn,true,2)
        mkTx(optEls,x+PAD+28,iy+9,11,T.t0,"Spam Interval",false)
        mkTx(optEls,x+PAD+28,iy+24,8,T.t1,"Seconds between auto-flings",false)
        local mb=x+PAD+W-112; local bby=iy+(O_ROW-18)/2
        mkSq(optEls,mb,   bby,26,18,T.bg4,true,3); mkTx(optEls,mb+13,bby+3,12,T.warn,"-",true)
        table.insert(optBtn,{x=mb,y=bby,w=26,h=18})
        optBtn[#optBtn].fn=function() F.spamDelay=math.max(0.5,F.spamDelay-0.5); Settings.spamDelay=F.spamDelay; saveAll(); notify("Interval: "..string.format("%.1f",F.spamDelay).."s"); drawOpt() end
        mkSq(optEls,mb+30,bby,42,18,T.bg2,true,3); mkTx(optEls,mb+51,bby+4,9,T.t0,string.format("%.1f",F.spamDelay).."s",true)
        local pb=mb+76
        mkSq(optEls,pb,   bby,26,18,T.bg4,true,3); mkTx(optEls,pb+13,bby+3,12,T.ok,"+",true)
        table.insert(optBtn,{x=pb,y=bby,w=26,h=18})
        optBtn[#optBtn].fn=function() F.spamDelay=math.min(60,F.spamDelay+0.5); Settings.spamDelay=F.spamDelay; saveAll(); notify("Interval: "..string.format("%.1f",F.spamDelay).."s"); drawOpt() end
        iy+=O_ROW+O_GAP
    end

    -- ACTIONS
    secBar("ACTIONS")

    btnRow(T.err,"Force Reset","Kill character, bypassing reset-lock","RESET")
    optBtn[#optBtn].fn=function() doForceReset() end

    btnRow(T.move,"Server Info","Show current server details","OPEN")
    optBtn[#optBtn].fn=function()
        if siOpen then siOpen=false; clearSI() else siOpen=true; drawSI() end
    end

    btnRow(T.accS,"Customize Theme","Change accent colour and background","OPEN")
    optBtn[#optBtn].fn=function()
        if thmOpen then thmOpen=false; clearThm() else thmOpen=true; drawThm() end
    end

    btnRow(T.util,"Save Settings","Save all feature states and positions","SAVE")
    optBtn[#optBtn].fn=function()
        Settings.pX=pX; Settings.pY=pY
        Settings.optX=optX; Settings.optY=optY
        Settings.thmX=thmX; Settings.thmY=thmY
        Settings.iconX=iconX; Settings.iconY=iconY
        Settings.sortMode=sortMode
        saveAll(); notify("Settings saved")
    end
end

