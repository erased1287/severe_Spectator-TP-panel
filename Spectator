if _G.SPV6_Post then pcall(function() _G.SPV6_Post:Disconnect() end) end
_G.SPV6_Post=RunService.PostLocal:Connect(function()
    pcall(function()
        if fPhase=="idle" then return end
        local myHRP=getHRP(); if not myHRP then fPhase="idle"; fFrames=0; return end
        if fPhase=="fling" then
            local tgt=findP(fTarget)
            local thrp=tgt and tgt.Character and tgt.Character:FindFirstChild("HumanoidRootPart")
            if thrp then
                local vel=F.sustained and F_SVEL or F_QVEL
                local tCF; pcall(function() tCF=thrp.CFrame end)
                if tCF then
                    local tp=tCF.Position
                    pcall(function() myHRP.Velocity=Vector3.new(math.random(-vel,vel),math.random(vel/3,vel),math.random(-vel,vel)) end)
                    pcall(function() myHRP.RotVelocity=Vector3.new(math.random(-600,600),math.random(-600,600),math.random(-600,600)) end)
                    pcall(function() myHRP.CFrame=CFrame.new(tp.X,tp.Y,tp.Z) end)
                end
            end
            fFrames-=1; if fFrames<=0 then fPhase="return"; fFrames=F_RF end; return
        end
        if fPhase=="return" then
            if fSaved then pcall(function()
                myHRP.CFrame=CFrame.new(fSaved.x,fSaved.y,fSaved.z)
                myHRP.Velocity=Vector3.new(0,0,0); myHRP.RotVelocity=Vector3.new(0,0,0)
            end) end
            fFrames-=1; if fFrames<=0 then fPhase="idle"; fSaved=nil end
        end
    end)
end)

