local function initIcon()
    -- resolve default position every time until valid coords are set
    local vpx,vpy=getVP()
    if iconX<=0 then iconX=vpx-ICO_W-14 end
    if iconY<=0 then iconY=vpy-ICO_H-14 end
    -- clamp in case viewport changed
    iconX=clamp(iconX,0,vpx-ICO_W)
    iconY=clamp(iconY,0,vpy-ICO_H)
end

local function drawIcon()
    local ix,iy=iconX,iconY
    local hov=inR(mx,my,ix,iy,ICO_W,ICO_H)
    fR(ix+3,iy+3,ICO_W,ICO_H,T.blk,0.3)
    fR(ix,iy,ICO_W,ICO_H,hov and T.bg4 or T.bg2)
    sR(ix,iy,ICO_W,ICO_H,hov and T.acc or T.brdr,0.9,1)
    -- top accent bar
    fR(ix,iy,ICO_W,2,hov and T.acc or T.accD)
    tx(ix+ICO_W/2,iy+ICO_H/2-7,13,T.acc,"S",true)
    -- active indicator dots
    local anyOn=F.diedTp or F.thirdP or F.antiVoid or F.antiAFK or F.instantInt or F.spamFling
    if anyOn then
        fR(ix+ICO_W-9,iy+4,6,6,T.ok)
    end
end

