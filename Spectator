-- INPUT
-- ============================================================
local function pollMouse()
    local p=UIS:GetMouseLocation(); mx,my=p.X,p.Y
    local lH=isleftpressed(); lClick=lH and not prevL; lRel=not lH and prevL; prevL=lH
end

local function handleInput()
    -- icon mode
    if not panelOpen then
        if lClick and inR(mx,my,iconX,iconY,ICO_W,ICO_H) then
            icoDrag=true; icoDX=mx-iconX; icoDY=my-iconY
        end
        if icoDrag and isleftpressed() then
            local vpx,vpy=getVP()
            iconX=clamp(mx-icoDX,0,vpx-ICO_W); iconY=clamp(my-icoDY,0,vpy-ICO_H)
        end
        if lRel and icoDrag then
            local moved=math.abs(mx-(iconX+icoDX))>4 or math.abs(my-(iconY+icoDY))>4
            if not moved then panelOpen=true end
            icoDrag=false
        end
        return
    end

    -- theme drag
    if thmOpen then
        if lClick and thmHdr and inR(mx,my,thmHdr.x,thmHdr.y,thmHdr.w,thmHdr.h) then
            thmDrag=true; thmDX=mx-thmX; thmDY=my-thmY
        end
        if thmDrag and isleftpressed() then
            local vpx,vpy=getVP(); local W=420
            local ra=math.ceil(#AccPre/5); local rb=math.ceil(#BgPre/3)
            local swH,swG=50,5
            local H=O_HDR+(O_SEC+12)+ra*(swH+swG)+10+(O_SEC+12)+rb*(swH+swG)+18
            thmX=clamp(mx-thmDX,0,vpx-W); thmY=clamp(my-thmDY,0,vpy-H)
            drawThm()
        end
        if lRel then thmDrag=false end
        if lClick and not thmDrag then
            if thmClose and inR(mx,my,thmClose.x,thmClose.y,thmClose.w,thmClose.h) then
                thmOpen=false; clearThm(); clickCd=0.2; return
            end
            for i,b in ipairs(thmAcc) do
                if inR(mx,my,b.x,b.y,b.w,b.h) then
                    local p=AccPre[i]; T.acc=p.a; T.accS=p.s; T.accD=p.d
                    saveAll(); drawThm(); if optOpen then drawOpt() end; clickCd=0.15; return
                end
            end
            for i,b in ipairs(thmBg) do
                if inR(mx,my,b.x,b.y,b.w,b.h) then
                    local p=BgPre[i]; T.bg0=p.b0;T.bg1=p.b1;T.bg2=p.b2;T.bg3=p.b3;T.bg4=p.b4;T.line=p.li;T.brdr=p.br
                    saveAll(); drawThm(); if optOpen then drawOpt() end; clickCd=0.15; return
                end
            end
        end
        if lClick then return end
    end

    -- server info
    if siOpen then
        if lClick then
            if siClose and inR(mx,my,siClose.x,siClose.y,siClose.w,siClose.h) then
                siOpen=false; clearSI(); clickCd=0.2; return
            end
            for _,b in ipairs(siCopyBtns) do
                if inR(mx,my,b.x,b.y,b.w,b.h) then
                    pcall(function() setclipboard(b.val) end)
                    notify(b.lbl..": "..b.val.." (copied)"); clickCd=0.2; return
                end
            end
            if siMain and not inR(mx,my,siMain.x,siMain.y,siMain.w,siMain.h) then
                siOpen=false; clearSI()
            end
        end
    end

    -- options drag
    if optOpen then
        if lClick and optHdr and inR(mx,my,optHdr.x,optHdr.y,optHdr.w,optHdr.h) then
            optDrag=true; optDX=mx-optX; optDY=my-optY
        end
        if optDrag and isleftpressed() then
            local vpx,vpy=getVP(); optX=clamp(mx-optDX,0,vpx-OW); optY=clamp(my-optDY,0,vpy-OH); drawOpt()
        end
        if lRel then
            if optDrag then Settings.optX=optX; Settings.optY=optY end
            optDrag=false
        end
        if lClick and not optDrag then
            if optClose and inR(mx,my,optClose.x,optClose.y,optClose.w,optClose.h) then
                optOpen=false; clearOpt(); clickCd=0.2; return
            end
            for _,tb in ipairs(optTog) do
                if inR(mx,my,tb.x,tb.y,tb.w,tb.h) then tb.fn(); drawOpt(); clickCd=0.2; return end
            end
            for _,bb in ipairs(optBtn) do
                if inR(mx,my,bb.x,bb.y,bb.w,bb.h) then bb.fn(); clickCd=0.25; return end
            end
        end
        if lClick then return end
    end

    local ph=panelH()
    -- main drag
    local dW=PW-(BTN_H*2)-BTN_W-18
    if lClick and inR(mx,my,pX,pY,dW,HDR_H) then dragPh=1; dragOX=mx-pX; dragOY=my-pY end
    if dragPh==1 then if math.abs(mx-(pX+dragOX))>2 or math.abs(my-(pY+dragOY))>2 then dragPh=2 end end
    if dragPh==2 and isleftpressed() then
        local vpx,vpy=getVP(); pX=clamp(mx-dragOX,0,vpx-PW); pY=clamp(my-dragOY,0,vpy-60); return
    end
    if lRel then
        if dragPh==2 then Settings.pX=pX; Settings.pY=pY end
        dragPh=0
    end

    if not inR(mx,my,pX,pY,PW,ph) then return end
    if not lClick then return end
    if clickCd>0 then return end

    -- OPT
    local obx=pX+PW-BTN_W*2-12; local oby=pY+(HDR_H-BTN_H)/2
    if inR(mx,my,obx,oby,BTN_W,BTN_H) then
        if optOpen then optOpen=false; clearOpt() else optOpen=true; drawOpt() end
        clickCd=0.2; return
    end
    -- minimize to icon
    local clX=pX+PW-BTN_H-5; local clY=pY+(HDR_H-BTN_H)/2
    if inR(mx,my,clX,clY,BTN_H,BTN_H) then
        panelOpen=false
        if optOpen then optOpen=false; clearOpt() end
        if siOpen  then siOpen=false;  clearSI()  end
        if thmOpen then thmOpen=false; clearThm() end
        clickCd=0.3; return
    end
    -- sort
    local sy2=pY+HDR_H+(TOOL_H-18)/2
    if inR(mx,my,pX+PAD,sy2,72,18) then
        sortMode=(sortMode+1)%2; Settings.sortMode=sortMode; clickCd=0.2; return
    end
    -- paging
    local fy=pY+panelH()-FOOT_H
    local prevX=pX+PW-(BTN_H*2)-7; local nextX=pX+PW-BTN_H-4; local arBY=fy+(FOOT_H-BTN_H)/2
    local maxPg=math.max(0,math.ceil(#list/PAGE)-1)
    if inR(mx,my,prevX,arBY,BTN_H,BTN_H) and pageIdx>0 then pageIdx-=1; clickCd=0.12; return end
    if inR(mx,my,nextX,arBY,BTN_H,BTN_H) and pageIdx<maxPg then pageIdx+=1; clickCd=0.12; return end
    -- row buttons
    local b1X=pX+RB1_OFF; local b2X=b1X+RBW+RBG; local b3X=b2X+RBW+RBG
    local pSt=pageIdx*PAGE+1; local pEn=math.min(pSt+PAGE-1,#list)
    for slot=1,pEn-pSt+1 do
        local p=list[pSt+slot-1]; if p==LocalPlayer then continue end
        local ry=rowY(slot); local by2=ry+(ROW_H-BTN_H)/2
        if inR(mx,my,b1X,by2,RBW,BTN_H) then teleportTo(p); clickCd=0.35; return end
        if inR(mx,my,b2X,by2,RBW,BTN_H) then F.spamTarget=p.Name; startFling(p.Name); clickCd=0.35; return end
        if inR(mx,my,b3X,by2,RBW,BTN_H) then
            if specP==p then stopSpec() else startSpec(p) end; clickCd=0.35; return
        end
        -- name click = copy uid
        if inR(mx,my,pX+28,ry,b1X-pX-32,ROW_H) then
            pcall(function() setclipboard(tostring(p.UserId)) end)
            notify(p.Name.." UID: "..tostring(p.UserId).." (copied)"); clickCd=0.3; return
        end
    end
end

