            li={T.line.R,T.line.G,T.line.B},
            br={T.brdr.R,T.brdr.G,T.brdr.B},
        }
        writefile(SAVE_FILE, crypt.json.encode(d))
    end)
end

local function loadTheme()
    pcall(function()
        local raw = readfile(SAVE_FILE)
        if not raw then return end
        local d = crypt.json.decode(raw)
        if not d then return end
        local function c(t) return t and Color3.new(t[1],t[2],t[3]) end
        if d.a  then T.acc =c(d.a)  end
        if d.aS then T.accS=c(d.aS) end
        if d.aD then T.accD=c(d.aD) end
        if d.b0 then T.bg0 =c(d.b0) end
        if d.b1 then T.bg1 =c(d.b1) end
        if d.b2 then T.bg2 =c(d.b2) end
        if d.b3 then T.bg3 =c(d.b3) end
        if d.b4 then T.bg4 =c(d.b4) end
        if d.li then T.line=c(d.li)  end
        if d.br then T.brdr=c(d.br)  end
    end)
end

