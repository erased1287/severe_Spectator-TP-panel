-- INPUT
-- =============================================================
local function pollMouse()
    local p=UIS:GetMouseLocation(); mx,my=p.X,p.Y
    local lH=isleftpressed()
    lClick=lH and not prevL; lRel=not lH and prevL; prevL=lH
end

local function handleInput()
    -- icon drag (always active when panel is closed)
    if not panelOpen then
        if lClick and inR(mx,my,iconX,iconY,ICO_W,ICO_H) then
            icoDrag=true; icoDX=mx-iconX; icoDY=my-iconY
        end
        if icoDrag and isleftpressed() then
            local vpx,vpy=getVP()
            iconX=clamp(mx-icoDX,0,vpx-ICO_W); iconY=clamp(my-icoDY,0,vpy-ICO_H)
        end
        if lRel then
            -- only open panel if mouse didn't move (i.e. was a click not a drag)
            if icoDrag and math.abs(mx-(iconX+icoDX))<=3 and math.abs(my-(iconY+icoDY))<=3 then
                panelOpen=true; icoDrag=false
            else
                icoDrag=false
            end
        end
        -- simpler approach: click with no movement = open
        if lClick and inR(mx,my,iconX,iconY,ICO_W,ICO_H) and not icoDrag then
            -- handled above via drag start, just in case:
        end
        return
    end

    -- theme panel
    if thmOpen then
        if lClick then
            if thmClose and inR(mx,my,thmClose.x,thmClose.y,thmClose.w,thmClose.h) then
                thmOpen=false; clearThm(); clickCd=0.25; return
            end
            for i,b in ipairs(thmAcc) do
                if inR(mx,my,b.x,b.y,b.w,b.h) then
                    local p=AccPre[i]; T.acc=p.a; T.accS=p.s; T.accD=p.d
                    saveTheme(); drawThm(); if optOpen then drawOpt() end; clickCd=0.2; return
                end
            end
            for i,b in ipairs(thmBg) do
                if inR(mx,my,b.x,b.y,b.w,b.h) then
                    local p=BgPre[i]
                    T.bg0=p.b0;T.bg1=p.b1;T.bg2=p.b2;T.bg3=p.b3;T.bg4=p.b4;T.line=p.li;T.brdr=p.br
                    saveTheme(); drawThm(); if optOpen then drawOpt() end; clickCd=0.2; return
                end
            end
        end
        if lClick then return end
    end

    -- server info
    if siOpen and lClick then
        if siClose and inR(mx,my,siClose.x,siClose.y,siClose.w,siClose.h) then
            siOpen=false; clearSI(); clickCd=0.25; return
        end
        if siMain and not inR(mx,my,siMain.x,siMain.y,siMain.w,siMain.h) then siOpen=false; clearSI() end
    end

    -- options drag
    if optOpen then
        if lClick and optHdr and inR(mx,my,optHdr.x,optHdr.y,optHdr.w,optHdr.h) then
            optDrag=true; optDX=mx-optX; optDY=my-optY
        end
        if optDrag and isleftpressed() then
            local vpx,vpy=getVP(); optX=clamp(mx-optDX,0,vpx-OW); optY=clamp(my-optDY,0,vpy-OH); drawOpt()
        end
        if lRel then optDrag=false end
        if lClick and not optDrag then
            if optClose and inR(mx,my,optClose.x,optClose.y,optClose.w,optClose.h) then
                optOpen=false; clearOpt(); clickCd=0.25; return
            end
            for _,tb in ipairs(optTog) do
                if inR(mx,my,tb.x,tb.y,tb.w,tb.h) then tb.fn(); drawOpt(); clickCd=0.25; return end
            end
            for _,bb in ipairs(optBtn) do
                if inR(mx,my,bb.x,bb.y,bb.w,bb.h) then bb.fn(); clickCd=0.3; return end
            end
        end
        if lClick then return end
    end

    local ph = panelH()

    -- main panel drag (header area, avoiding buttons on right)
    local dW=PW-(BTN_H*2)-BTN_W-20
    if lClick and inR(mx,my,pX,pY,dW,HDR_H) then
        dragPh=1; dragOX=mx-pX; dragOY=my-pY
    end
    if dragPh==1 then
        if math.abs(mx-(pX+dragOX))>2 or math.abs(my-(pY+dragOY))>2 then dragPh=2 end
    end
    if dragPh==2 and isleftpressed() then
        local vpx,vpy=getVP()
        pX=clamp(mx-dragOX,0,vpx-PW); pY=clamp(my-dragOY,0,vpy-60); return
    end
    if lRel then dragPh=0 end

    if not inR(mx,my,pX,pY,PW,ph) then return end
    if not lClick then return end
    if clickCd > 0 then return end

    -- OPT
    local obx=pX+PW-BTN_W*2-14; local oby=pY+(HDR_H-BTN_H)/2
    if inR(mx,my,obx,oby,BTN_W,BTN_H) then
        if optOpen then optOpen=false; clearOpt() else optOpen=true; optX=0; drawOpt() end
        clickCd=0.25; return
    end

    -- close (minimize to icon)
    local clX=pX+PW-BTN_H-6; local clY=pY+(HDR_H-BTN_H)/2
    if inR(mx,my,clX,clY,BTN_H,BTN_H) then
        panelOpen=false
        if optOpen then optOpen=false; clearOpt() end
        if siOpen  then siOpen=false;  clearSI()  end
        if thmOpen then thmOpen=false; clearThm() end
        clickCd=0.4; return
    end

    -- sort
    local sy2=pY+HDR_H+(TOOL_H-20)/2
    if inR(mx,my,pX+PAD,sy2,76,20) then sortMode=(sortMode+1)%2; clickCd=0.25; return end

    -- paging
    local fy=pY+panelH()-FOOT_H
    local prevX=pX+PW-(BTN_H*2)-8; local nextX=pX+PW-BTN_H-4
    local arBY=fy+(FOOT_H-BTN_H)/2
    local maxPg=math.max(0,math.ceil(#list/PAGE)-1)
    if inR(mx,my,prevX,arBY,BTN_H,BTN_H) and pageIdx>0 then pageIdx-=1; clickCd=0.15; return end
    if inR(mx,my,nextX,arBY,BTN_H,BTN_H) and pageIdx<maxPg then pageIdx+=1; clickCd=0.15; return end

    -- row buttons
    local b1X=pX+RB1_OFF; local b2X=b1X+RBW+RBG; local b3X=b2X+RBW+RBG
    local pSt=pageIdx*PAGE+1; local pEn=math.min(pSt+PAGE-1,#list)
    for slot=1,pEn-pSt+1 do
        local p=list[pSt+slot-1]
        if p==LocalPlayer then continue end
        local ry=rowY(slot); local by2=ry+(ROW_H-BTN_H)/2
        if inR(mx,my,b1X,by2,RBW,BTN_H) then teleportTo(p); clickCd=0.4; return end
        if inR(mx,my,b2X,by2,RBW,BTN_H) then F.spamTarget=p.Name; startFling(p.Name); clickCd=0.4; return end
        if inR(mx,my,b3X,by2,RBW,BTN_H) then
            if specP==p then stopSpec() else startSpec(p) end; clickCd=0.4; return
        end
        if inR(mx,my,pX+30,ry,b1X-pX-34,ROW_H) then copyUID(p); clickCd=0.35; return end
    end
end

