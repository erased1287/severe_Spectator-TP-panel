local function drawHdr()
    fR(pX,pY,PW,HDR_H,T.bg2)
    fR(pX,pY+HDR_H-1,PW,1,T.line)
    fR(pX,pY,IR,HDR_H,T.acc)
    tx(pX+26,pY+HDR_H/2-8,13,T.acc,"S",true)
    tx(pX+46,pY+15,14,T.t0,"SEVERE",false)
    tx(pX+102,pY+15,14,T.t2,"PLAYERS",false)
    tx(pX+46,pY+31,9,T.t2,tostring(#list-1).." in session",false)
    if fPhase ~= "idle" then
        local lbl = fPhase=="fling" and ("fling "..fFrames.."f") or ("return "..fFrames.."f")
        tx(pX+PW/2,pY+31,9,T.err,lbl,true)
    end

    -- OPT button
    local obx=pX+PW-BTN_W*2-14; local oby=pY+(HDR_H-BTN_H)/2
    local obH=inR(mx,my,obx,oby,BTN_W,BTN_H)
    fR(obx,oby,BTN_W,BTN_H,obH and T.acc or T.bg4)
    sR(obx,oby,BTN_W,BTN_H,T.brdr,0.5,1)
    tx(obx+BTN_W/2,oby+BTN_H/2-6,11,obH and T.wht or T.t1,"OPT",true)

    -- close (minimizes to icon)
    local clX=pX+PW-BTN_H-6; local clY=pY+(HDR_H-BTN_H)/2
    local clH=inR(mx,my,clX,clY,BTN_H,BTN_H)
    fR(clX,clY,BTN_H,BTN_H,clH and T.err or T.bg4)
    sR(clX,clY,BTN_H,BTN_H,T.brdr,0.5,1)
    tx(clX+BTN_H/2,clY+BTN_H/2-6,11,T.t0,"_",true)
end

local function drawPanel()
    local ph = panelH()
    fR(pX-1,pY-1,PW+2,ph+2,T.brdr)
    fR(pX,pY,PW,ph,T.bg1)
    fR(pX,pY,IR,ph,T.acc)
    drawHdr()

    -- toolbar
    local ty=pY+HDR_H
    fR(pX,ty,PW,TOOL_H,T.bg2)
    fR(pX,ty+TOOL_H-1,PW,1,T.line)
    fR(pX,ty,IR,TOOL_H,T.acc)
    local sy=ty+(TOOL_H-20)/2; local sH=inR(mx,my,pX+PAD,sy,76,20)
    fR(pX+PAD,sy,76,20,sH and T.accD or T.bg4)
    sR(pX+PAD,sy,76,20,T.brdr,0.4,1)
    tx(pX+PAD+5,sy+4,9,T.t2,"SORT",false)
    tx(pX+PAD+38,sy+4,9,T.t0,sortMode==0 and "NAME" or "DIST",false)
    tx(pX+PW/2,ty+(TOOL_H-9)/2,9,T.t2,#list.." players",true)

    -- rows
    local total=   #list
    local maxPg=   math.max(0,math.ceil(total/PAGE)-1)
    pageIdx=       clamp(pageIdx,0,maxPg)
    local pStart=  pageIdx*PAGE+1
    local pEnd=    math.min(pStart+PAGE-1,total)
    local pCount=  pEnd-pStart+1
    local b1X=pX+RB1_OFF; local b2X=b1X+RBW+RBG; local b3X=b2X+RBW+RBG

    for i=1,PAGE do
        local ry=rowY(i)
        local base=(i%2==0) and T.bg3 or T.bg1
        fR(pX,ry,PW,ROW_H,base); fR(pX,ry+ROW_H-1,PW,1,T.line)
        if i>pCount then tx(pX+PAD+4,ry+ROW_H/2-5,9,T.line,"--",false); continue end
        local pi=pStart+i-1; local p=list[pi]
        local isL=p==LocalPlayer; local isSp=specP==p
        local isFT=fTarget==p.Name and fPhase~="idle"
        local isHv=inR(mx,my,pX,ry,PW,ROW_H) and not isL
        local bg=base
        if isFT  then bg=Color3.fromRGB(34,10,10) end
        if isSp  then bg=Color3.fromRGB(10,28,20) end
        if isHv  then bg=T.bg4 end
        fR(pX,ry,PW,ROW_H,bg); fR(pX,ry+ROW_H-1,PW,1,T.line)
        fR(pX,ry,IR,ROW_H,isFT and T.err or (isSp and T.ok or (isL and T.acc or T.bg2)))
        tx(pX+8,ry+ROW_H/2-5,8,T.t2,string.format("%02d",pi),false)
        local name=p.DisplayName or p.Name
        if #name>12 then name=name:sub(1,10)..".." end
        tx(pX+30,ry+8,12,isFT and T.err or (isSp and T.ok or (isL and T.accS or T.t0)),name,false)
        if isL then
            tx(pX+30,ry+24,9,T.acc,"YOU",false)
        else
            local hp,mxhp=getHP(p)
            local pct=clamp(hp/math.max(mxhp,1),0,1)
            local hc=pct>.6 and T.ok or (pct>.3 and T.warn or T.err)
            fR(pX+30,ry+26,100,3,T.bg4); fR(pX+30,ry+26,math.floor(100*pct),3,hc)
            local d=distTo(p)
            local ds=d==math.huge and "?" or (d>9999 and ">9k" or math.floor(d).."m")
            tx(pX+138,ry+24,9,d<20 and T.warn or T.t2,ds,false)
        end
        if not isL then
            local by2=ry+(ROW_H-BTN_H)/2; local busy=fPhase~="idle"
            -- TP
            local tpH=inR(mx,my,b1X,by2,RBW,BTN_H)
            fR(b1X,by2,RBW,BTN_H,tpH and T.acc or T.accD); sR(b1X,by2,RBW,BTN_H,T.brdr,0.35,1)
            tx(b1X+RBW/2,by2+BTN_H/2-6,10,T.wht,"TP",true)
            -- FLING
            local flH=inR(mx,my,b2X,by2,RBW,BTN_H) and not busy
            local flBg=isFT and T.err or (busy and T.bg4 or (flH and T.err or Color3.fromRGB(175,32,48)))
            fR(b2X,by2,RBW,BTN_H,flBg); sR(b2X,by2,RBW,BTN_H,T.brdr,0.35,1)
            tx(b2X+RBW/2,by2+BTN_H/2-6,9,busy and T.t2 or T.wht,isFT and "..." or "FLING",true)
            -- SPEC
            local spH=inR(mx,my,b3X,by2,RBW,BTN_H)
            local spBg=isSp and (spH and T.err or Color3.fromRGB(155,40,40)) or (spH and T.ok or Color3.fromRGB(36,140,88))
            fR(b3X,by2,RBW,BTN_H,spBg); sR(b3X,by2,RBW,BTN_H,T.brdr,0.35,1)
            tx(b3X+RBW/2,by2+BTN_H/2-6,9,T.wht,isSp and "STOP" or "SPEC",true)
        end
    end

    -- footer
    local fy=pY+ph-FOOT_H
    fR(pX,fy,PW,FOOT_H,T.bg2); fR(pX,fy,PW,1,T.line)
    local fRail = specP and T.ok or ((F.diedTp or F.thirdP or F.spamFling or F.antiVoid or F.antiAFK or F.instantInt) and T.acc or T.bg4)
    fR(pX,fy,IR,FOOT_H,fRail)
    local chipX=pX+PAD+4
    local function chip(col,label)
        local w=6+(#label)*7
        fR(chipX,fy+(FOOT_H-14)/2,w,14,T.bg4)
        sR(chipX,fy+(FOOT_H-14)/2,w,14,col,0.4,1)
        tx(chipX+w/2,fy+(FOOT_H-14)/2+3,9,col,label,true)
        chipX+=w+4
    end
    if specP      then chip(T.ok,  "SPEC:"..specP.Name:upper():sub(1,5)) end
    if F.diedTp   then chip(T.tele,"DIEDTP") end
    if F.thirdP   then chip(T.vis, "3P") end
    if F.antiVoid then chip(T.move,"AVOID") end
    if F.antiAFK  then chip(T.util,"AFK") end
    if F.instantInt then chip(T.ok,"INTR") end
    if F.spamFling  then chip(T.err,"SPAM") end
    if F.sustained  then chip(T.warn,"SUST") end
    local anyActive = specP or F.diedTp or F.thirdP or F.spamFling or F.sustained or F.antiVoid or F.antiAFK or F.instantInt
    if not anyActive then tx(pX+PAD+4,fy+(FOOT_H-9)/2,9,T.t2,"IDLE",false) end

    -- page arrows
    local total2=#list; local maxPg2=math.max(0,math.ceil(total2/PAGE)-1)
    local prevX=pX+PW-(BTN_H*2)-8; local nextX=pX+PW-BTN_H-4
    local arBY=fy+(FOOT_H-BTN_H)/2
    local canPrev=pageIdx>0; local canNext=pageIdx<maxPg2
    fR(prevX,arBY,BTN_H,BTN_H,canPrev and (inR(mx,my,prevX,arBY,BTN_H,BTN_H) and T.acc or T.bg4) or T.bg3)
    sR(prevX,arBY,BTN_H,BTN_H,T.brdr,0.4,1)
    tx(prevX+BTN_H/2,arBY+BTN_H/2-6,11,canPrev and T.t0 or T.t2,"<",true)
    fR(nextX,arBY,BTN_H,BTN_H,canNext and (inR(mx,my,nextX,arBY,BTN_H,BTN_H) and T.acc or T.bg4) or T.bg3)
    sR(nextX,arBY,BTN_H,BTN_H,T.brdr,0.4,1)
    tx(nextX+BTN_H/2,arBY+BTN_H/2-6,11,canNext and T.t0 or T.t2,">",true)
    tx(pX+PW-(BTN_H*2)-44,fy+(FOOT_H-9)/2,9,T.t2,(pageIdx+1).."/"..(maxPg2+1),false)

    -- spec HUD bar
    if specP then
        local vpx,_=getVP(); local hw=300; local hx=vpx/2-hw/2
        fR(hx,26,hw,22,T.bg2); fR(hx,26,IR,22,T.ok)
        tx(vpx/2,29,11,T.ok,"SPECTATING  "..specP.Name:upper().."   |   "..math.floor(distTo(specP)).."m",true)
    end
end

