-- =============================================================
-- HELPERS
-- =============================================================
local function clamp(v,lo,hi) return math.max(lo,math.min(hi,v)) end

local function inR(px2,py2,rx,ry,rw,rh)
    return px2>=rx and px2<=rx+rw and py2>=ry and py2<=ry+rh
end

local function getVP()
    local cam = workspace.CurrentCamera
    if not cam then return 1920,1080 end
    local v = cam.ViewportSize
    return v.X or 1920, v.Y or 1080
end

local function distTo(p)
    local mc = LocalPlayer.Character
    local tc = p.Character
    if not mc or not tc then return math.huge end
    local mr = mc:FindFirstChild("HumanoidRootPart")
    local tr = tc:FindFirstChild("HumanoidRootPart")
    if not mr or not tr then return math.huge end
    local d = mr.Position - tr.Position
    return math.sqrt(d.X*d.X + d.Y*d.Y + d.Z*d.Z)
end

local function getHP(p)
    local c = p.Character
    if not c then return 0,100 end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h then return 0,100 end
    return h.Health, h.MaxHealth
end

local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function findP(name)
    if not name or name == "" then return nil end
    local q = name:lower()
    for _,p in Players:GetChildren() do
        if p ~= LocalPlayer then
            local ok1,n  = pcall(function() return p.Name end)
            local ok2,dn = pcall(function() return p.DisplayName end)
            if (ok1 and n:lower()==q) or (ok2 and dn:lower()==q) then return p end
        end
    end
    for _,p in Players:GetChildren() do
        if p ~= LocalPlayer then
            local ok1,n  = pcall(function() return p.Name end)
            local ok2,dn = pcall(function() return p.DisplayName end)
            if (ok1 and n:lower():sub(1,#q)==q) or (ok2 and dn:lower():sub(1,#q)==q) then return p end
        end
    end
    return nil
end

local function panelH() return HDR_H+TOOL_H+PAGE*ROW_H+FOOT_H end
local function rowY(i)  return pY+HDR_H+TOOL_H+(i-1)*ROW_H end

local function getSpawn()
    if F.avSpawn then return F.avSpawn end
    local pos = Vector3.new(0,50,0)
    pcall(function()
        local s = workspace:FindFirstChildOfClass("SpawnLocation")
        if not s then
            for _,v in workspace:GetDescendants() do
                if v:IsA("SpawnLocation") then s=v break end
            end
        end
        if s then pos = s.Position + Vector3.new(0,3,0) end
    end)
    F.avSpawn = pos
    return pos
end

-- =============================================================
-- PLAYER LIST
-- =============================================================
local function buildList()
    local others = {}
    for _,p in ipairs(Players:GetChildren()) do
        if p ~= LocalPlayer then table.insert(others,p) end
    end
    if sortMode == 1 then
        table.sort(others, function(a,b) return distTo(a)<distTo(b) end)
    else
        table.sort(others, function(a,b) return a.Name<b.Name end)
    end
    table.insert(others,1,LocalPlayer)
    list = others
end

-- =============================================================
-- SPECTATE
-- =============================================================
local function stopSpec()
    local prev = specP; specP = nil
    local cam = workspace.CurrentCamera
    local mc  = LocalPlayer.Character
    if cam and mc then
        local h = mc:FindFirstChildOfClass("Humanoid")
        if h then cam.CameraSubject = h end
    end
    if prev then notify("Stopped spectating " .. prev.Name) end
end

local function startSpec(p)
    if specP then stopSpec() end
    local c = p.Character
    if not c then notify("No character: " .. p.Name) return end
    local h = c:FindFirstChildOfClass("Humanoid")
    if not h then notify("No humanoid: " .. p.Name) return end
    specP = p
    local cam = workspace.CurrentCamera
    if cam then cam.CameraSubject = h end
    notify("Spectating " .. p.Name)
end

local function checkSpec()
    if not specP then return end
    local c = specP.Character
    if not c or not c:FindFirstChildOfClass("Humanoid") then stopSpec() end
end

-- =============================================================
-- TELEPORT
-- =============================================================
local function teleportTo(p)
    local tc = p.Character; local mc = LocalPlayer.Character
    if not tc or not mc then notify("TP failed: no character") return end
    local tr = tc:FindFirstChild("HumanoidRootPart")
    local mr = mc:FindFirstChild("HumanoidRootPart")
    if not tr or not mr then notify("TP failed: no RootPart") return end
    tpTgt  = {x=tr.Position.X, y=tr.Position.Y+2, z=tr.Position.Z}
    tpRoot = mr; tpFr = 10
    notify("Teleporting to " .. p.Name)
end

local function tickTP()
    if tpFr <= 0 or not tpRoot or not tpTgt then return end
    pcall(function()
        tpRoot.CFrame   = CFrame.new(tpTgt.x, tpTgt.y, tpTgt.z)
        tpRoot.Velocity = Vector3.new(0,0,0)
    end)
    tpFr -= 1
    if tpFr <= 0 then tpTgt=nil; tpRoot=nil end
end

-- =============================================================
-- FLING
-- =============================================================
local function startFling(name)
    if fPhase ~= "idle" then return end
    if not name or name == "" then notify("No target") return end
    local target = findP(name)
    if not target then notify("Not found: " .. tostring(name)) return end
    local thrp = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
    if not thrp then notify(target.Name .. " has no character") return end
    local myHRP = getHRP()
    if not myHRP then notify("You have no character") return end
    local pos = myHRP.Position
    fSaved  = {x=pos.X, y=pos.Y, z=pos.Z}
    fTarget = target.Name
    fFrames = F.sustained and F_SF or F_QF
    fPhase  = "fling"
    if F.sustained then
        notify("Sustained fling on " .. target.Name)
    else
        notify("Quick fling on " .. target.Name)
    end
end

