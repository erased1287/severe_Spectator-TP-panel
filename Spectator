local function initIcon()
    if iconInit then return end
    local vpx,vpy = getVP()
    iconX = vpx - ICO_W - 14
    iconY = vpy - ICO_H - 14
    iconInit = true
end

local function drawIcon()
    local ix,iy = iconX, iconY
    local hov = inR(mx,my,ix,iy,ICO_W,ICO_H)
    -- shadow
    fR(ix+3,iy+3,ICO_W,ICO_H,T.blk,0.35)
    -- body
    fR(ix,iy,ICO_W,ICO_H,hov and T.bg3 or T.bg2)
    sR(ix,iy,ICO_W,ICO_H,hov and T.acc or T.brdr,0.8,1)
    -- accent top edge
    fR(ix,iy,ICO_W,2,T.acc)
    -- "S" letter centered
    tx(ix+ICO_W/2, iy+ICO_H/2-8, 14, T.acc, "S", true)
    -- tiny dot grid (decorative)
    local dotC = hov and T.accS or T.t2
    for di=0,2 do
        fR(ix+8+di*5, iy+ICO_H-10, 2, 2, dotC)
    end
end

