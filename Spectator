    local x,y = optX,optY

    mkSq(optEls,x-6,y-6,OW+12,OH+12,T.blk,true,16,0.55)
    mkSq(optEls,x,y,OW,OH,T.bg1,true,10)
    mkSq(optEls,x,y,OW,OH,T.brdr,false,10,1,1)
    mkSq(optEls,x,y,IR,OH,T.acc,true,2)
    mkSq(optEls,x,y,OW,O_HDR,T.bg2,true,10)
    mkSq(optEls,x,y+O_HDR-1,OW,1,T.line,true)
    mkSq(optEls,x,y,IR,O_HDR,T.acc,true,2)
    mkCi(optEls,x+28,y+O_HDR/2,13,T.acc,false,24,2)
