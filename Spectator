        F.antiVoid=not F.antiVoid; F.avCooldown=0
        if F.antiVoid then F.avSpawn=nil; getSpawn() end
        if F.antiVoid then notify("Anti-Void ON") else notify("Anti-Void OFF") end
    end

    togRow(T.util,"Anti-AFK","Prevent AFK kick by simulating activity",F.antiAFK)
    optTog[#optTog].fn=function()
        F.antiAFK=not F.antiAFK
        if F.antiAFK then enableAntiAFK() else disableAntiAFK() end
        if F.antiAFK then notify("Anti-AFK ON") else notify("Anti-AFK OFF") end
    end

    togRow(T.ok,"Instant Interact","Set ProximityPrompt hold duration to 0",F.instantInt)
    optTog[#optTog].fn=function()
        F.instantInt=not F.instantInt
        if F.instantInt then enableInstantInteract() else disableInstantInteract() end
    end

    -- FLING CONFIG section
    secBar("FLING CONFIG")

    togRow(T.err,"Spam Fling","Auto-fling last FLING target repeatedly",F.spamFling)
    optTog[#optTog].fn=function()
        F.spamFling=not F.spamFling; F.spamLast=os.clock()
        if F.spamFling then notify("Spam fling ON") else notify("Spam fling OFF") end
    end

    togRow(T.warn,"Sustained","Longer fling for fall-damage maps",F.sustained)
    optTog[#optTog].fn=function()
        F.sustained=not F.sustained
        if F.sustained then notify("Sustained ON") else notify("Sustained OFF") end
    end

    -- Interval row
    do
        mkSq(optEls,x+PAD,iy,W,O_ROW,T.bg3,true,6)
        mkSq(optEls,x+PAD,iy,IR,O_ROW,T.warn,true,2)
        mkTx(optEls,x+PAD+30,iy+10,12,T.t0,"Spam Interval",false)
        mkTx(optEls,x+PAD+30,iy+26,9,T.t1,"Seconds between auto-flings",false)
        local mb=x+PAD+W-118; local bby=iy+(O_ROW-20)/2
        mkSq(optEls,mb,   bby,28,20,T.bg4,true,4)
        mkTx(optEls,mb+14,bby+4,13,T.warn,"-",true)
        table.insert(optBtn,{x=mb,y=bby,w=28,h=20})
        optBtn[#optBtn].fn=function() F.spamDelay=math.max(0.5,F.spamDelay-0.5); notify("Interval: "..string.format("%.1f",F.spamDelay).."s"); drawOpt() end
        mkSq(optEls,mb+32,bby,46,20,T.bg2,true,4)
        mkTx(optEls,mb+55,bby+5,10,T.t0,string.format("%.1f",F.spamDelay).."s",true)
        local pb=mb+82
        mkSq(optEls,pb,   bby,28,20,T.bg4,true,4)
        mkTx(optEls,pb+14,bby+4,13,T.ok,"+",true)
        table.insert(optBtn,{x=pb,y=bby,w=28,h=20})
        optBtn[#optBtn].fn=function() F.spamDelay=math.min(60,F.spamDelay+0.5); notify("Interval: "..string.format("%.1f",F.spamDelay).."s"); drawOpt() end
        iy+=O_ROW+O_GAP
    end

    -- ACTIONS section
    secBar("ACTIONS")

    btnRow(T.err,"Force Reset","Kill character, bypassing reset-lock","RESET")
    optBtn[#optBtn].fn=function() doForceReset() end

    btnRow(T.util,"Copy My User ID","Copies your UserId to clipboard","COPY")
    optBtn[#optBtn].fn=function() copyUID(nil) end

    btnRow(T.move,"Server Info","Show current server details","OPEN")
    optBtn[#optBtn].fn=function()
        if siOpen then siOpen=false; clearSI() else siOpen=true; drawSI() end
    end

    btnRow(T.accS,"Customize Theme","Change accent and background","OPEN")
    optBtn[#optBtn].fn=function()
        if thmOpen then thmOpen=false; clearThm() else thmOpen=true; drawThm() end
    end
end

