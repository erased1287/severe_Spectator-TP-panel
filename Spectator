-- FEATURES
-- =============================================================
local function tickDiedTP(dt)
    if not F.diedTp then return end
    if F.dCooldown > 0 then F.dCooldown -= dt return end
    pcall(function()
        local c = LocalPlayer.Character
        if not c then F.dWasAlive=false return end
        local r = c:FindFirstChild("HumanoidRootPart")
        local h = c:FindFirstChildOfClass("Humanoid")
        if not r or not h then F.dWasAlive=false return end
        local alive = h.Health > 0
        if alive then F.dLastPos = r.Position end
        if F.dWasAlive and not alive then F.dDeathPos=F.dLastPos; F.dWasDead=true end
        if F.dWasDead and alive and F.dDeathPos then
            local saved = F.dDeathPos
            task.spawn(function()
                task.wait(0.18)
                local nr = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if nr then
                    nr.CFrame   = CFrame.new(saved + Vector3.new(0,3,0))
                    nr.Velocity = Vector3.new(0,0,0)
                    notify("DiedTP: returned to death spot")
                end
            end)
            F.dWasDead=false; F.dDeathPos=nil; F.dCooldown=2
        end
        F.dWasAlive = alive
    end)
end

local function tickThirdP()
    if not F.thirdP then return end
    pcall(function()
        local c   = LocalPlayer.Character
        local cam = workspace.CurrentCamera
        if not c or not cam then return end
        local head = c:FindFirstChild("Head") or c.PrimaryPart
        if not head then return end
        local look = cam.CFrame.LookVector
        cam.CFrame = CFrame.new(
            head.Position - look*F.tDist + Vector3.new(0,F.tHeight,0),
            head.Position)
    end)
end

local function tickSpam()
    if not F.spamFling then return end
    if fPhase ~= "idle" then return end
    if F.spamTarget == "" then return end
    local now = os.clock()
    if now - F.spamLast < F.spamDelay then return end
    F.spamLast = now
    startFling(F.spamTarget)
end

local function tickAntiVoid(dt)
    if not F.antiVoid then return end
    if F.avCooldown > 0 then F.avCooldown -= dt return end
    pcall(function()
        local c = LocalPlayer.Character
        if not c then return end
        local r = c:FindFirstChild("HumanoidRootPart")
        if not r then return end
        if r.Position.Y < F.avThresh then
            local sp = getSpawn()
            r.CFrame   = CFrame.new(sp)
            r.Velocity = Vector3.new(0,0,0)
            F.avCooldown = 2
            notify("Anti-Void: teleported to spawn")
        end
    end)
end

-- Anti-AFK: simulate input to prevent kick
local function enableAntiAFK()
    if F.afkConn then return end
    F.afkConn = task.spawn(function()
        while F.antiAFK do
            pcall(function()
                -- move mouse slightly to reset AFK timer
                local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize
                if vp then
                    local cx = (vp.X or 960)/2
                    local cy = (vp.Y or 540)/2
                    mousemoveabs(cx + math.random(-1,1), cy + math.random(-1,1))
                end
            end)
            task.wait(60)
        end
        F.afkConn = nil
    end)
end

local function disableAntiAFK()
    F.antiAFK = false
    F.afkConn = nil
end

-- Instant Interact: fetch offset then loop writing 0 to ProximityPrompt hold duration
local function enableInstantInteract()
    if F.iiLoop then return end
    task.spawn(function()
        -- try to fetch live offset
        local offset = nil
        pcall(function()
            local ok, res = pcall(function()
                return game:HttpGet("https://offsets.ntgetwritewatch.workers.dev/offsets.json")
            end)
            if ok and res then
                local data = crypt.json.decode(res)
                if data and data.ProximityPromptHoldDuraction then
                    offset = tonumber(data.ProximityPromptHoldDuraction, 16)
                end
            end
        end)
        F.iiOffset = offset
        if offset then
            notify("Instant Interact ON (offset " .. string.format("0x%X", offset) .. ")")
        else
            notify("Instant Interact ON (no offset, skipping memory write)")
        end

        F.iiLoop = true
        while F.iiLoop do
            pcall(function()
                if F.iiOffset then
                    for _,obj in ipairs(game:GetDescendants()) do
                        if obj.ClassName == "ProximityPrompt" then
                            pcall(function() memory.writef32(obj, F.iiOffset, 0) end)
                        end
                    end
                else
                    -- fallback: set HoldDuration via property
                    for _,obj in ipairs(game:GetDescendants()) do
                        if obj.ClassName == "ProximityPrompt" then
                            pcall(function() obj.HoldDuration = 0 end)
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

local function disableInstantInteract()
    F.iiLoop = false
    F.iiOffset = nil
    notify("Instant Interact OFF")
end

local function doForceReset()
    local c = LocalPlayer.Character
    if not c then notify("No character") return end
    local done = false
    pcall(function()
        local h = c:FindFirstChildOfClass("Humanoid")
        if h then memory.writef32(h, 0x194, 0); done=true end
    end)
    if not done then
        pcall(function()
            local h = c:FindFirstChildOfClass("Humanoid")
            if h then h.Health=0; done=true end
        end)
    end
    if done then notify("Force Reset done") else notify("Force Reset failed") end
end

local function copyUID(p)
    local id = (p or LocalPlayer).UserId
    local nm = (p or LocalPlayer).Name
    pcall(function() setclipboard(tostring(id)) end)
    notify(nm .. " UID: " .. tostring(id) .. " (copied)")
end

