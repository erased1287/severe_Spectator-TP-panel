local checkT=0; local optRdT=0

RunService.Render:Connect(function(dt)
    pollMouse()
    if clickCd>0 then clickCd-=dt end
    tickDiedTP(dt); tickThirdP(); tickTP(); tickSpam(); tickAntiVoid(dt)
    if not panelOpen then
        initIcon(); drawIcon(); pcall(handleInput); return
    end
    buildList()
    checkT+=dt; if checkT>=0.5 then checkT=0; checkSpec() end
    if optOpen then optRdT+=dt; if optRdT>=0.3 then optRdT=0; drawOpt() end end
    pcall(handleInput); pcall(drawPanel)
end)

